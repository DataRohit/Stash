{
  "name": "stash",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source collaborative workspace for Markdown, HTML, spreadsheets, Kanban boards, structured team views, and charts, powered by Next.js, Convex, Clerk, and Yjs.",
  "keywords": [
    "authentication",
    "charts",
    "clerk",
    "collaboration",
    "convex",
    "database",
    "document-management",
    "html",
    "kanban",
    "knowledge-base",
    "markdown",
    "multi-tenant",
    "nextjs",
    "open-source",
    "organizations",
    "project-management",
    "real-time",
    "self-hosted",
    "spreadsheet",
    "typescript",
    "version-control",
    "workspace",
    "yjs"
  ],
  "homepage": "https://github.com/DataRohit/Stash#readme",
  "bugs": {
    "url": "https://github.com/DataRohit/Stash/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DataRohit/Stash.git"
  },
  "license": "MIT",
  "author": "Rohit Vilas Ingole (https://github.com/DataRohit)",
  "scripts": {
    "build": "next build",
    "check": "pnpm package:check && pnpm format:check && pnpm lint && pnpm typecheck && pnpm knip && pnpm spellcheck && pnpm secrets && pnpm markdownlint && pnpm comments:check && pnpm build",
    "comments:check": "node tools/check-no-comments.mjs",
    "db:dashboard": "convex dashboard",
    "db:setup": "cross-env CONVEX_AGENT_MODE=anonymous convex dev --once",
    "dev:db": "cross-env CONVEX_AGENT_MODE=anonymous convex dev",
    "dev:local": "pnpm db:setup && concurrently --kill-others-on-fail -n convex,web,dash -c blue,green,magenta \"pnpm dev:db\" \"pnpm dev:web\" \"node tools/print-convex-dashboard.mjs\"",
    "dev:web": "next dev",
    "fix": "biome check --write --unsafe . && eslint . --fix && sort-package-json",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "knip": "knip",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --no-warn-ignored",
    "markdownlint": "markdownlint-cli2",
    "package:check": "sort-package-json --check",
    "package:fix": "sort-package-json",
    "prepare": "husky",
    "secrets": "secretlint --secretlintignore .gitignore \"**/*\"",
    "spellcheck": "cspell --no-progress --no-must-find-files \"**/*.{ts,tsx,md,css,json,mjs}\"",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "biome check --write --no-errors-on-unmatched",
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ],
    "*": [
      "secretlint --secretlintignore .gitignore"
    ]
  },
  "dependencies": {
    "@clerk/nextjs": "7.5.12",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@dicebear/collection": "^9.4.3",
    "@dicebear/core": "^9.4.3",
    "@lezer/highlight": "^1.2.3",
    "@resvg/resvg-js": "^2.6.2",
    "@tanstack/react-virtual": "^3.14.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "cspell": "^10.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "knip": "^6.25.0",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.0",
    "secretlint": "^13.0.2",
    "sort-package-json": "^4.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  }
}
